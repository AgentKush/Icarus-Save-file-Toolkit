<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Icarus_Toolkit.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="using:Icarus_Toolkit.Utils"
    mc:Ignorable="d"
    d:DesignWidth="1200"
    d:DesignHeight="700"
    MinWidth="900"
    MinHeight="550"
    WindowStartupLocation="CenterScreen"
    Width="1200"
    Height="700"
    x:Class="Icarus_Toolkit.Views.MainWindow"
    Icon="/Assets/icarus_logo.ico"
    Title="{Binding CharacterDisplayName, StringFormat='Icarus Toolkit - {0}', FallbackValue='Icarus Toolkit'}"
    TransparencyLevelHint="AcrylicBlur"
    Background="Transparent"
    ExtendClientAreaToDecorationsHint="False">

    <Window.Resources>
        <utils:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Styles>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity=".65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- Row 0: Game Path Selection -->
            <Border Grid.Row="0" Padding="10" BorderThickness="0,0,0,1" BorderBrush="#333333">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" Text="Save Path:" FontWeight="SemiBold" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding GamePath}" Foreground="#AAAAAA"
                                   TextTrimming="CharacterEllipsis" MaxWidth="700" />
                        <Button Command="{Binding SelectGameFolderButtonClickedCommand}" Content="Auto-Detect / Select"
                                IsVisible="{Binding ValidGamePath, Converter={StaticResource InverseBooleanConverter}}" />
                        <Button Command="{Binding ChangeGameFolderCommand}" Content="Change Folder"
                                IsVisible="{Binding ValidGamePath}" />
                    </StackPanel>
                    <TextBlock IsVisible="{Binding IsPathWarningVisible}" Foreground="#FF5555" FontSize="11"
                               TextWrapping="Wrap"
                               Text="{Binding PathWarningText}" />
                </StackPanel>
            </Border>

            <!-- Row 1: Character Selection and Controls -->
            <Border Grid.Row="1" Padding="10" BorderThickness="0,0,0,1" BorderBrush="#333333"
                    IsVisible="{Binding ValidGamePath}">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center" Text="Character:" />
                        <ComboBox
                            x:Name="CharacterSelectCombobox"
                            ItemsSource="{Binding CharacterList}"
                            SelectedIndex="{Binding SelectedCharacterIndex}"
                            MinWidth="200">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CharacterName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Command="{Binding LoadSelectedCharacterCommand}" Content="{Binding LoadText}" />
                        <Button Command="{Binding BackupDataCommand}" Content="Backup" />
                        <CheckBox
                            VerticalAlignment="Center"
                            IsChecked="{Binding EditMode}"
                            IsVisible="{Binding IsCharacterLoaded}"
                            Content="Edit Mode" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding EditMode}">
                        <Button Command="{Binding DuplicateCharacterCommand}" Content="Duplicate" />
                        <Button Command="{Binding RemoveCharacterCommand}" Content="Remove" />
                        <Button Command="{Binding ExportDataCommand}" Content="Save All Data" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Row 2: Tab Content Area -->
            <TabControl Grid.Row="2" IsVisible="{Binding IsCharacterLoaded}" Margin="8">

                <!-- ===== OVERVIEW TAB ===== -->
                <TabItem Header="Overview">
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="16">

                            <!-- Character Info -->
                            <Border BorderThickness="0,0,0,1" BorderBrush="#444444" Padding="0,0,0,12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Character Information" FontSize="14" FontWeight="Bold" />
                                    <Grid ColumnDefinitions="120,*,120,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Name:" />
                                        <TextBox Grid.Row="0" Grid.Column="1" Watermark="Character Name"
                                                 Text="{Binding EditedName}"
                                                 IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Location:" />
                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditedLocation}"
                                                 IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Prospect ID:" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditedLastProspectId}"
                                                 IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="Last Played:" />
                                        <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center"
                                                   Text="{Binding LastPlayedDisplay}" Foreground="#CCCCCC" />
                                        <CheckBox Grid.Row="2" Grid.Column="0" Content="Is Dead"
                                                  IsChecked="{Binding EditedIsDead}" IsEnabled="{Binding EditMode}" />
                                        <CheckBox Grid.Row="2" Grid.Column="1" Content="Is Abandoned"
                                                  IsChecked="{Binding EditedIsAbandoned}" IsEnabled="{Binding EditMode}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Experience & Level -->
                            <Border BorderThickness="0,0,0,1" BorderBrush="#444444" Padding="0,0,0,12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Experience &amp; Level" FontSize="14" FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <Image Height="50" Source="/Assets/icarus_logo.png" />
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Text="{Binding XPLevel, StringFormat='Level {0}'}"
                                                       FontSize="18" FontWeight="Bold" />
                                            <Slider Width="300" Minimum="0"
                                                    Maximum="{Binding MaxXP}"
                                                    Value="{Binding EditedXP}"
                                                    IsEnabled="{Binding EditMode}" />
                                            <TextBlock Text="{Binding EditedXP, StringFormat='{}{0:N0} XP'}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== TALENTS TAB ===== -->
                <TabItem Header="Talents">
                    <Grid RowDefinitions="*,Auto" Margin="10">
                        <DataGrid
                            Grid.Row="0"
                            ItemsSource="{Binding SelectedCharacterTalents}"
                            SelectedIndex="{Binding SelectedTalentIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Talent RowName" Binding="{Binding RowName}" Width="*" />
                                <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <TextBox Watermark="Talent RowName" Text="{Binding NewTalentRowName}" Width="250" />
                            <NumericUpDown Value="{Binding NewTalentRank}" Minimum="1" Maximum="10" Width="80" />
                            <Button Command="{Binding AddTalentCommand}" Content="Add Talent" />
                            <Button Command="{Binding RemoveTalentCommand}" Content="Remove Selected" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== COSMETICS TAB ===== -->
                <TabItem Header="Cosmetics">
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Character Cosmetics" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Edit your character's appearance values. Changes are applied when you save." Foreground="#AAAAAA" />
                            <Grid ColumnDefinitions="180,200,180,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                <!-- Row 0 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Head:" />
                                <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding CosmeticHead}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Hair:" />
                                <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding CosmeticHair}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 1 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Hair Color:" />
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding CosmeticHairColor}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="Body:" />
                                <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding CosmeticBody}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 2 -->
                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Body Color:" />
                                <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding CosmeticBodyColor}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="Skin Tone:" />
                                <NumericUpDown Grid.Row="2" Grid.Column="3" Value="{Binding CosmeticSkinTone}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 3 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Head Tattoo:" />
                                <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding CosmeticHeadTattoo}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Text="Head Scar:" />
                                <NumericUpDown Grid.Row="3" Grid.Column="3" Value="{Binding CosmeticHeadScar}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 4 -->
                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Facial Hair:" />
                                <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding CosmeticHeadFacialHair}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Text="Cap Logo:" />
                                <NumericUpDown Grid.Row="4" Grid.Column="3" Value="{Binding CosmeticCapLogo}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 5 -->
                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Voice:" />
                                <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding CosmeticVoice}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Text="Eye Color:" />
                                <NumericUpDown Grid.Row="5" Grid.Column="3" Value="{Binding CosmeticEyeColor}" Minimum="0" IsEnabled="{Binding EditMode}" />
                                <!-- Row 6 -->
                                <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                                          Content="Male Character" IsChecked="{Binding CosmeticIsMale}"
                                          IsEnabled="{Binding EditMode}" Margin="0,8,0,0" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== FLAGS TAB ===== -->
                <TabItem Header="Flags">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Character Flags" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Unlocked tech tree nodes, talent blueprints, mission rewards, and progression milestones."
                                       Foreground="#AAAAAA" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding SelectedCharacterFlags}"
                            SelectedIndex="{Binding SelectedFlagIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="True"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                <DataGridTextColumn Header="Flag Name" Binding="{Binding Name}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <ComboBox ItemsSource="{Binding AvailableFlags}"
                                      SelectedItem="{Binding SelectedNewFlag}"
                                      MinWidth="350" MaxDropDownHeight="300"
                                      PlaceholderText="Select a flag to add..." />
                            <Button Command="{Binding AddFlagCommand}" Content="Add Flag" />
                            <Button Command="{Binding RemoveFlagCommand}" Content="Remove Selected" />
                            <Button Command="{Binding UnlockAllCharacterFlagsCommand}" Content="Unlock All" FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== WORKSHOP ITEMS (META INVENTORY) TAB ===== -->
                <TabItem Header="Workshop Items">
                    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Orbital Workshop Inventory" FontSize="14" FontWeight="Bold" />
                                <TextBlock VerticalAlignment="Center" Foreground="#AAAAAA">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} item(s)">
                                            <Binding Path="InventoryItemCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="Items crafted in the workshop available to take on drops. Loaded from MetaInventory.json."
                                       Foreground="#AAAAAA" IsVisible="{Binding HasMetaInventory}" />
                            <TextBlock Text="No MetaInventory.json found. Craft workshop items in-game first."
                                       Foreground="#FF9800" IsVisible="{Binding HasMetaInventory, Converter={StaticResource InverseBooleanConverter}}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                        IsVisible="{Binding HasMetaInventory}">
                                <TextBlock VerticalAlignment="Center" Text="Inventory ID:" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding MetaInventoryId}" Foreground="#CCCCCC" />
                            </StackPanel>
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding MetaInventoryItems}"
                            SelectedIndex="{Binding SelectedInventoryItemIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item Name" Binding="{Binding DisplayName}" Width="200" />
                                <DataGridTextColumn Header="Row Name" Binding="{Binding RowName}" Width="*" />
                                <DataGridTextColumn Header="Table" Binding="{Binding DataTable}" Width="120" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Count}" Width="50" />
                                <DataGridTextColumn Header="Durability" Binding="{Binding Durability}" Width="100" />
                                <DataGridTextColumn Header="Alterations" Binding="{Binding Alterations}" Width="200" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- Item Picker -->
                        <StackPanel Grid.Row="2" Spacing="4" Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <TextBlock Text="Add from known items:" Foreground="#AAAAAA" FontSize="11" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox ItemsSource="{Binding WorkshopItemPickerList}"
                                          SelectedItem="{Binding SelectedItemPicker}"
                                          MinWidth="400" MaxDropDownHeight="350"
                                          PlaceholderText="Browse known workshop items..." />
                                <NumericUpDown Value="{Binding NewInventoryItemCount}" Minimum="1" Maximum="999" Width="100" />
                                <Button Command="{Binding AddInventoryItemCommand}" Content="Add Item" />
                                <Button Command="{Binding RemoveInventoryItemCommand}" Content="Remove Selected" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Manual entry -->
                        <StackPanel Grid.Row="3" Spacing="4" Margin="0,4,0,0" IsVisible="{Binding EditMode}">
                            <TextBlock Text="Or enter a MetaRow name manually:" Foreground="#AAAAAA" FontSize="11" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Watermark="Item MetaRow (e.g. Pickaxe_Titanium)" Text="{Binding NewInventoryItemName}" Width="350" />
                                <Button Command="{Binding AddInventoryItemCommand}" Content="Add Manual" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== PETS / MOUNTS TAB ===== -->
                <TabItem Header="Pets &amp; Mounts">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Pets &amp; Mounts" FontSize="14" FontWeight="Bold" />
                                <TextBlock VerticalAlignment="Center" Foreground="#AAAAAA">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} creature(s) loaded from Mounts.json">
                                            <Binding Path="MountCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="Tamed creatures, mounts, combat pets, and farm animals. Name and level are editable. Binary data (genetics, talents, lineage) is preserved during saves."
                                       Foreground="#AAAAAA" TextWrapping="Wrap"
                                       IsVisible="{Binding HasMounts}" />
                            <TextBlock Text="No Mounts.json found in your save folder. Tame a creature in-game first, then reload to see your pets here."
                                       Foreground="#FF9800" TextWrapping="Wrap"
                                       IsVisible="{Binding HasMounts, Converter={StaticResource InverseBooleanConverter}}" />
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,280">
                            <!-- Mount List -->
                            <DataGrid
                                Grid.Column="0"
                                ItemsSource="{Binding MountDisplayItems}"
                                SelectedIndex="{Binding SelectedMountIndex}"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                IsReadOnly="True"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="1"
                                BorderBrush="#444444">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="60" />
                                    <DataGridTextColumn Header="Species" Binding="{Binding TypeDisplay}" Width="130" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                                    <DataGridTextColumn Header="Data (bytes)" Binding="{Binding BlobSize}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Separator -->
                            <Border Grid.Column="1" Width="1" Background="#444444" Margin="8,0" />

                            <!-- Detail Panel -->
                            <StackPanel Grid.Column="2" Spacing="8" IsVisible="{Binding EditMode}">
                                <TextBlock Text="Edit Selected Mount" FontWeight="SemiBold" />
                                <TextBlock Text="Name:" Foreground="#AAAAAA" Margin="0" />
                                <TextBox Text="{Binding EditedMountName}" Watermark="Mount name" />
                                <TextBlock Text="Level:" Foreground="#AAAAAA" Margin="0" />
                                <NumericUpDown Value="{Binding EditedMountLevel}" Minimum="1" Maximum="50" />
                                <TextBlock Text="Type (internal):" Foreground="#AAAAAA" Margin="0" />
                                <TextBox Text="{Binding EditedMountType}" Watermark="e.g. Buffalo, Wolf" />
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button Command="{Binding SelectMountCommand}" Content="Load" />
                                    <Button Command="{Binding ApplyMountEditsCommand}" Content="Apply Changes" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <Button Command="{Binding RemoveMountCommand}" Content="Remove Selected Mount" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== PROFILE TAB ===== -->
                <TabItem Header="Profile">
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Player Profile" FontSize="14" FontWeight="Bold" />
                            <Border Background="#332200" BorderBrush="#665500" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,4">
                                <TextBlock TextWrapping="Wrap" Foreground="#FFCC44" FontSize="11"
                                           Text="NOTE: Profile data (flags, talents, resources) may be overwritten by the Icarus game server when you connect online. For best results: close the game completely, make edits, then launch. If changes revert, the server is re-syncing your profile. Character-level edits (XP, name, cosmetics) are more reliable." />
                            </Border>
                            <Grid ColumnDefinitions="120,*,120,*" RowDefinitions="Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="User ID:" />
                                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"
                                           Text="{Binding ProfileUserId}" Foreground="#CCCCCC" />
                                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="Data Version:" />
                                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"
                                           Text="{Binding ProfileDataVersion}" Foreground="#CCCCCC" />
                            </Grid>

                            <!-- Meta Resources (Currency) -->
                            <Border Height="1" Background="#444444" Margin="0,4" />
                            <TextBlock Text="Meta Resources (Currency)" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="Ren, Exotics, Credits, Refunds and other resource types." Foreground="#AAAAAA" />
                            <DataGrid
                                ItemsSource="{Binding ProfileMetaResources}"
                                SelectedIndex="{Binding SelectedMetaResourceIndex}"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                                MaxHeight="200"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="1"
                                BorderBrush="#444444">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Resource (MetaRow)" Binding="{Binding MetaRow}" Width="*" />
                                    <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="150" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding EditMode}">
                                <Button Command="{Binding AddMetaResourceCommand}" Content="Add Resource" />
                                <Button Command="{Binding RemoveMetaResourceCommand}" Content="Remove Selected" />
                            </StackPanel>

                            <!-- Account Flags (Blueprints & Unlocks) -->
                            <Border Height="1" Background="#444444" Margin="0,4" />
                            <TextBlock Text="Account Flags (Blueprints &amp; Unlocks)" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="Blueprint unlocks, mission rewards, Great Hunt progress, and workshop grants. These are the flags that unlock craftable items and gear."
                                       Foreground="#AAAAAA" TextWrapping="Wrap" />
                            <DataGrid
                                ItemsSource="{Binding ProfileAccountFlags}"
                                SelectedIndex="{Binding SelectedAccountFlagIndex}"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                IsReadOnly="True"
                                MaxHeight="250"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="1"
                                BorderBrush="#444444">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="Account Flag Name" Binding="{Binding Name}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding EditMode}">
                                <ComboBox ItemsSource="{Binding AvailableAccountFlags}"
                                          SelectedItem="{Binding SelectedNewAccountFlag}"
                                          MinWidth="350" MaxDropDownHeight="300"
                                          PlaceholderText="Select an account flag to unlock..." />
                                <Button Command="{Binding AddAccountFlagCommand}" Content="Add Flag" />
                                <Button Command="{Binding RemoveAccountFlagCommand}" Content="Remove Selected" />
                                <Button Command="{Binding UnlockAllAccountFlagsCommand}" Content="Unlock All" FontWeight="Bold" />
                            </StackPanel>

                            <!-- Profile Talents -->
                            <Border Height="1" Background="#444444" Margin="0,4" />
                            <TextBlock Text="Profile Talents (Prospects &amp; Unlocks)" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="Completed prospects, story progression, and granted talents. Adding prospect entries here may help unlock blueprint-gated items."
                                       Foreground="#AAAAAA" TextWrapping="Wrap" />
                            <DataGrid
                                ItemsSource="{Binding ProfileTalents}"
                                SelectedIndex="{Binding SelectedProfileTalentIndex}"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                                MaxHeight="400"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="1"
                                BorderBrush="#444444">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Talent RowName" Binding="{Binding RowName}" Width="*" />
                                    <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding EditMode}">
                                <TextBox Watermark="Talent/Prospect RowName" Text="{Binding NewProfileTalentRowName}" Width="300" />
                                <NumericUpDown Value="{Binding NewProfileTalentRank}" Minimum="1" Maximum="10" Width="80" />
                                <Button Command="{Binding AddProfileTalentCommand}" Content="Add Talent" />
                                <Button Command="{Binding RemoveProfileTalentCommand}" Content="Remove Selected" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== ACCOLADES TAB ===== -->
                <TabItem Header="Accolades">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Accolades (Achievements)" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Achievement tracking and progression stats. Each entry has a RowName identifier and a point value."
                                       Foreground="#AAAAAA" TextWrapping="Wrap" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding AccoladeEntries}"
                            SelectedIndex="{Binding SelectedAccoladeIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Accolade (RowName)" Binding="{Binding RowName}" Width="*" />
                                <DataGridTextColumn Header="Points" Binding="{Binding NumPoints}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <TextBox Watermark="Accolade RowName" Text="{Binding NewAccoladeRowName}" Width="250" />
                            <NumericUpDown Value="{Binding NewAccoladePoints}" Minimum="0" Maximum="999999" Width="120" />
                            <Button Command="{Binding AddAccoladeCommand}" Content="Add Accolade" />
                            <Button Command="{Binding RemoveAccoladeCommand}" Content="Remove Selected" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== BESTIARY TAB ===== -->
                <TabItem Header="Bestiary">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Bestiary (Creature Discoveries)" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Tracks creatures you've discovered and their research points."
                                       Foreground="#AAAAAA" TextWrapping="Wrap" />
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding BestiaryEntries}"
                            SelectedIndex="{Binding SelectedBestiaryIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="{Binding EditMode, Converter={StaticResource InverseBooleanConverter}}"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Creature (RowName)" Binding="{Binding RowName}" Width="*" />
                                <DataGridTextColumn Header="Points" Binding="{Binding NumPoints}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <TextBox Watermark="Creature RowName" Text="{Binding NewBestiaryRowName}" Width="250" />
                            <NumericUpDown Value="{Binding NewBestiaryPoints}" Minimum="0" Maximum="999999" Width="120" />
                            <Button Command="{Binding AddBestiaryEntryCommand}" Content="Add Entry" />
                            <Button Command="{Binding RemoveBestiaryEntryCommand}" Content="Remove Selected" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== LOADOUTS TAB ===== -->
                <TabItem Header="Loadouts">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Equipment Loadout Presets" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Saved loadout presets for quickly equipping items from the orbital workshop before a drop."
                                       Foreground="#AAAAAA" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LoadoutCount, StringFormat='Total Loadouts: {0}'}"
                                       Foreground="#88CCFF" FontSize="12" />
                        </StackPanel>

                        <!-- Main content: loadout list + slot viewer side by side -->
                        <Grid Grid.Row="1" ColumnDefinitions="*,8,*">
                            <!-- Left: Loadout list -->
                            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Text="Loadouts" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <DataGrid
                                    Grid.Row="1"
                                    ItemsSource="{Binding LoadoutDisplayItems}"
                                    SelectedIndex="{Binding SelectedLoadoutIndex}"
                                    CanUserReorderColumns="False"
                                    CanUserResizeColumns="True"
                                    IsReadOnly="True"
                                    GridLinesVisibility="Horizontal"
                                    BorderThickness="1"
                                    BorderBrush="#444444">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="Items" Binding="{Binding SlotCount}" Width="60" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- Right: Slot viewer for selected loadout -->
                            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,4"
                                           Text="{Binding SelectedLoadout.Name, StringFormat='Slots — {0}', FallbackValue='Select a loadout to view slots'}" />
                                <DataGrid
                                    Grid.Row="1"
                                    ItemsSource="{Binding SelectedLoadoutSlots}"
                                    SelectedIndex="{Binding SelectedSlotIndex}"
                                    CanUserReorderColumns="False"
                                    CanUserResizeColumns="True"
                                    IsReadOnly="True"
                                    GridLinesVisibility="Horizontal"
                                    BorderThickness="1"
                                    BorderBrush="#444444">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding SlotIndex}" Width="40" />
                                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*" />
                                        <DataGridTextColumn Header="MetaRow" Binding="{Binding MetaRow}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Slot edit controls -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                            Margin="0,4,0,0" IsVisible="{Binding EditMode}">
                                    <ComboBox ItemsSource="{Binding WorkshopItemPickerList}"
                                              SelectedItem="{Binding SelectedSlotItemPicker}"
                                              PlaceholderText="Pick an item..."
                                              Width="200" />
                                    <Button Command="{Binding AddLoadoutSlotCommand}" Content="Add Slot" />
                                    <Button Command="{Binding RemoveLoadoutSlotCommand}" Content="Remove Slot" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Bottom: loadout management controls -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,8,0,0" IsVisible="{Binding EditMode}">
                            <TextBox Watermark="Loadout Name" Text="{Binding NewLoadoutName}" Width="250" />
                            <Button Command="{Binding AddLoadoutCommand}" Content="Add Loadout" />
                            <Button Command="{Binding RemoveLoadoutCommand}" Content="Remove Selected" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ===== BACKUP & RESTORE TAB ===== -->
                <TabItem Header="Backups">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
                        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Backup &amp; Restore" FontSize="14" FontWeight="Bold" />
                            <TextBlock Foreground="#AAAAAA">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Manage save data backups. {0} backup(s) available.">
                                        <Binding Path="BackupCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <DataGrid
                            Grid.Row="1"
                            ItemsSource="{Binding BackupList}"
                            SelectedIndex="{Binding SelectedBackupIndex}"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            IsReadOnly="True"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="#444444">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Backup (Date/Time)" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Command="{Binding BackupDataCommand}" Content="Create Backup" />
                            <Button Command="{Binding RestoreBackupCommand}" Content="Restore Selected" />
                            <Button Command="{Binding DeleteBackupCommand}" Content="Delete Selected" />
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Row 3: Status Bar -->
            <Border Grid.Row="3" Padding="8" BorderThickness="0,1,0,0" BorderBrush="#333333">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Loading..." Foreground="#FF9800" FontWeight="Bold"
                                   IsVisible="{Binding IsWorking}" />
                        <TextBlock Text="{Binding InformationString}" Foreground="#FF9800"
                                   IsVisible="{Binding IsInformationStringVisible}" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenLogFolderCommand}"
                            IsVisible="{Binding IsWarningIconVisible}" Padding="4" Height="28">
                        <Image Source="/Assets/warning_icon.png" Height="18" />
                    </Button>
                    <ProgressBar Grid.Column="2" Value="{Binding Progress}"
                                 IsVisible="{Binding IsProgressVisible}"
                                 ShowProgressText="True" Width="180" Height="18" />
                </Grid>
            </Border>

        </Grid>
    </Panel>
</Window>
